<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lamarana Diallo</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Portfolio.styles.css" asp-append-version="true" />
</head>
<body class="bg-light text-dark">
    <header class="sticky-top shadow-sm bg-white">
        <nav class="navbar navbar-expand-lg navbar-light container">
            <a class="navbar-brand fs-4 fw-bold" asp-area="" asp-controller="Home" asp-action="Index">Lamarana Diallo</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="mainNav">
                <ul class="navbar-nav align-items-center gap-2">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="About">À propos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Skills">Compétences</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Projects">Projets</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Education">Formation</a></li>
                    <li class="nav-item"><a class="btn btn-primary btn-sm" asp-action="Contact">Contact</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <div class="container py-5">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-white border-top py-4">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div>
                <strong>© 2026 Lamarana Diallo</strong>
                <p class="mb-0 text-muted">Développeur Web & Bases de données</p>
            </div>
            <div class="d-flex gap-3">
                <a class="text-muted text-decoration-none" href="mailto:lamaranamamadousdiallo@gmail.com"><i class="bi bi-envelope me-1"></i>lamaranamamadousdiallo@gmail.com</a>
                <a class="text-muted text-decoration-none" href="tel:+221775365983"><i class="bi bi-telephone me-1"></i>+221 77 536 5983</a>
                <a class="text-muted text-decoration-none" href="https://github.com/lamarana" target="_blank" rel="noopener noreferrer"><i class="bi bi-github me-1"></i>GitHub</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
