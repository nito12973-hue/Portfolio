@model IEnumerable<Portfolio.Models.SkillCategory>
@{
    ViewData["Title"] = "Compétences";
}

<section class="bg-white rounded-4 shadow-sm p-4 p-lg-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <p class="text-uppercase text-muted small mb-1">Expertises</p>
            <h1 class="fw-bold mb-0">Mes compétences techniques</h1>
        </div>
        <span class="badge bg-primary text-white rounded-pill px-3 py-2">Bootstrap & responsive</span>
    </div>
    <div class="row g-4">
        @foreach (var category in Model)
        {
            <article class="col-12 col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi @category.IconClass fs-3 text-primary me-2"></i>
                            <h3 class="h5 mb-0">@category.Title</h3>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var skill in category.Skills)
                            {
                                <span class="badge bg-light text-dark border">@skill</span>
                            }
                        </div>
                    </div>
                </div>
            </article>
        }
    </div>
</section>
