@model IEnumerable<Portfolio.Models.ProjectCard>
@{
    ViewData["Title"] = "Projets";
}

<section class="bg-white rounded-4 shadow-sm p-4 p-lg-5">
    <div class="d-flex justify-content-between align-items-center gap-3 mb-4 flex-wrap">
        <div>
            <p class="text-uppercase text-muted small mb-1">Réalisations</p>
            <h1 class="fw-bold mb-0">Projets sélectionnés</h1>
        </div>
        <div class="d-flex gap-2">
            <span class="text-muted small d-none d-md-inline">Bootstrap, cartes et icônes</span>
            <a class="btn btn-sm btn-outline-primary" asp-controller="ProjectAdmin" asp-action="Create">Ajouter un projet</a>
        </div>
    </div>

    @if (ViewBag.ProjectAdded is string message)
    {
        <div class="alert alert-success mb-3" role="alert">@message</div>
    }

    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var project in Model)
        {
            <article class="col">
                <div class="card h-100 border-0 shadow-sm position-relative">
                    @if (project.Featured)
                    {
                        <span class="badge bg-primary position-absolute top-0 end-0 m-3">Projet principal</span>
                    }
                    <div class="card-body d-flex flex-column">
                        <h3 class="h5 fw-semibold">@project.Title</h3>
                        <p class="text-muted flex-grow-1">@project.Description</p>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (var tech in project.Technologies)
                            {
                                <span class="badge bg-light text-dark border">@tech</span>
                            }
                        </div>
                        <a class="btn btn-outline-secondary btn-sm align-self-start" href="@project.Link" target="_blank" rel="noopener noreferrer">
                            Voir le dépôt <i class="bi bi-arrow-up-right-square ms-1"></i>
                        </a>
                    </div>
                </div>
            </article>
        }
    </div>
</section>
