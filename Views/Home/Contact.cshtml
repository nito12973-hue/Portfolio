@model Portfolio.Models.ContactFormModel
@{
    ViewData["Title"] = "Contact";
    var github = ViewBag.GithubLink as string ?? "https://github.com/lamarana";
    var email = ViewBag.ContactEmail as string ?? "lamaranamamadousdiallo@gmail.com";
}

<section class="bg-white rounded-4 shadow-sm p-4 p-lg-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <p class="text-uppercase text-muted small mb-1">Contact</p>
            <h1 class="fw-bold mb-0">Entrons en contact</h1>
        </div>
        <span class="text-muted small"><i class="bi bi-telephone me-1"></i> Disponible pour des missions à distance</span>
    </div>

    @if (ViewBag.ContactSuccess is string success)
    {
        <div class="alert alert-success" role="alert">@success</div>
    }

    <div class="row gy-4">
        <div class="col-lg-6">
            <p class="text-muted mb-3">Envoyez-moi un message en précisant le sujet ou le projet à l’origine de votre demande. Je réponds généralement sous 48 heures.</p>
            <ul class="list-unstyled fw-semibold">
                <li class="mb-2">
                    <i class="bi bi-envelope-fill me-2 text-primary"></i>
                    <a class="text-decoration-none" href="mailto:@email">@email</a>
                </li>
                <li class="mb-2">
                    <i class="bi bi-telephone-fill me-2 text-success"></i>
                    <a class="text-decoration-none" href="tel:+221775365983">+221 77 536 5983</a>
                </li>
                <li>
                    <i class="bi bi-github me-2 text-dark"></i>
                    <a class="text-decoration-none" href="@github" target="_blank" rel="noopener noreferrer">GitHub</a>
                </li>
            </ul>
        </div>
        <div class="col-lg-6">
            <form method="post" asp-action="Contact" class="row g-3">
                <div class="col-12">
                    <label asp-for="Name" class="form-label">Nom</label>
                    <input asp-for="Name" class="form-control" />
                    <span class="text-danger small" asp-validation-for="Name"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span class="text-danger small" asp-validation-for="Email"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Message" class="form-label">Message</label>
                    <textarea asp-for="Message" class="form-control" rows="5"></textarea>
                    <span class="text-danger small" asp-validation-for="Message"></span>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Envoyer</button>
                </div>
                <div class="col-12">
                    <span class="text-muted small">Les champs marqués d'une astérisque sont obligatoires.</span>
                </div>
                <div class="col-12">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
