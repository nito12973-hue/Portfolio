@model Portfolio.Models.AboutViewModel
@{
    ViewData["Title"] = "À propos";
}

<section class="bg-white rounded-4 shadow-sm p-4 p-lg-5">
    <h1 class="fw-bold mb-3">Mon parcours</h1>
    <p class="lead text-muted">@Model.Story</p>
    <div class="alert alert-info border-info mt-4">
        <p class="mb-0">Administration de bases de données, supervision de clusters et automatisation des sauvegardes s’ajoutent à ma passion pour le développement web et mobile.</p>
    </div>
    <div class="row g-4 mt-4">
        <div class="col-md-6">
            <div class="border-start border-4 border-primary ps-3">
                <p class="text-uppercase text-muted small mb-1">Formation</p>
                <h2 class="h5 mb-2">@Model.Formation</h2>
                <p class="text-muted mb-0">J'enchaîne les projets concrets en parallèle des cours pour rester à jour sur les dernières pratiques du développement web et des bases de données.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="border-start border-4 border-success ps-3">
                <p class="text-uppercase text-muted small mb-1">Centres d’intérêt</p>
                <ul class="list-unstyled mb-0">
                    @foreach (var interest in Model.Interests)
                    {
                        <li class="d-flex align-items-start gap-2 mb-2">
                            <i class="bi bi-dot fs-5 text-success"></i>
                            <span class="text-muted">@interest</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</section>
