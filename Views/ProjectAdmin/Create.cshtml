@model Portfolio.Models.ProjectFormModel
@{
    ViewData["Title"] = "Ajouter un projet";
}

<section class="bg-white rounded-4 shadow-sm p-4 p-lg-5">
    <h1 class="fw-bold mb-3">Ajouter un projet déployé</h1>
    <p class="text-muted mb-4">Renseigne le titre, la description, les technologies utilisées et le lien vers le dépôt ou la démo.</p>

    <form asp-action="Create" method="post" class="row g-3">
        <div class="col-12">
            <label asp-for="Title" class="form-label">Titre</label>
            <input asp-for="Title" class="form-control" />
            <span class="text-danger small" asp-validation-for="Title"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span class="text-danger small" asp-validation-for="Description"></span>
        </div>
        <div class="col-12">
            <label asp-for="Technologies" class="form-label">Technologies (séparées par des virgules)</label>
            <input asp-for="Technologies" class="form-control" placeholder="Next.js, Node.js, MongoDB" />
            <span class="text-danger small" asp-validation-for="Technologies"></span>
        </div>
        <div class="col-12">
            <label asp-for="Link" class="form-label">Lien</label>
            <input asp-for="Link" class="form-control" placeholder="https://github.com/..." />
            <span class="text-danger small" asp-validation-for="Link"></span>
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="Featured" class="form-check-input" />
                <label asp-for="Featured" class="form-check-label">Mettre en avant ce projet</label>
            </div>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Ajouter le projet</button>
            <a asp-controller="Home" asp-action="Projects" class="btn btn-link">Annuler</a>
        </div>
    </form>
</section>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
